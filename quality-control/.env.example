# Camera Ingestion
RTSP_STREAM_URL=rtsp://admin:password@192.168.1.100/ch1/main
FPS_PROCESSING_LIMIT=30

# TensorRT Engine
TRT_ENGINE_PATH=/opt/models/patchcore_fp16.engine
ANOMALY_THRESHOLD_MIN=0.4
ANOMALY_THRESHOLD_MAX=0.6

# Active Learning Storage (MinIO)
MINIO_ENDPOINT=192.168.1.50:9000
MINIO_ACCESS_KEY=your_generic_access_key
MINIO_SECRET_KEY=your_generic_secret_key
ACTIVE_LEARNING_BUCKET=active-learning-buffer

# Label Studio Annotation
LABEL_STUDIO_URL=http://192.168.1.50:8080
LABEL_STUDIO_API_TOKEN=your_generic_api_token
LABEL_STUDIO_PROJECT_ID=1
